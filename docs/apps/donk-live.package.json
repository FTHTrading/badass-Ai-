{
  "name": "donk-live",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DONK operator live avatar — ElevenLabs Josh + animated face beside Nerve",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "setup:env": "powershell -ExecutionPolicy Bypass -File scripts/setup-env.ps1"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "hono": "^4.11.7",
    "@hono/node-server": "^1.19.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
